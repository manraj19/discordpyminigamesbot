# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# All previously hardcoded tokens are considered compromised and MUST be rotated
# in the respective dashboards before use.

# --- Production bot (minigames.py) ---
DISCORD_TOKEN=your-production-discord-bot-token
TOPGG_TOKEN=your-topgg-api-token
CRICAPI_KEY=your-cricapi-key

# --- Beta bot (minibeta.py) ---
DISCORD_TOKEN_BETA=your-beta-discord-bot-token
GEMINI_API_KEY=your-google-gemini-api-key
